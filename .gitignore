# Python
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info
.venv/
.pytest_cache/
.ruff_cache/
.cache/
models/

# Secrets / local env
.env
.env.*

# Restricted analytical data (never publish)
data/input/
data/processed/
data/reports/

# Internal Chinese drafts (outside public Git history)
finding/

# One-off / local helper scripts (not part of the public pipeline)
scripts/_*.py

# Generated outputs: ignore by default
outputs/tables/
outputs/figures/
outputs/models/
outputs/reports/

# Allow curated public release tables only
!outputs/public/
!outputs/public/**

# Allow selected full-regression text dumps (H1 / H2 / D1)
!outputs/models/
outputs/models/*
!outputs/models/h1_engagement_indirect.txt
!outputs/models/h2_indirect_period.txt
!outputs/models/h2_indirect_period_h2_m1_period.txt
!outputs/models/h2_indirect_period_h2_m2_composition.txt
!outputs/models/d1_indirect_peripheral.txt
!outputs/models/d1_indirect_peripheral_d1_m1_total_association.txt
!outputs/models/d1_indirect_peripheral_d1_m2_conditional_threshold.txt
